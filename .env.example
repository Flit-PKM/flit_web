# Backend API Base URL (dev server only)
# Used when running the Vite dev server; production build uses the same origin as the page.
# Default: http://localhost:8000
# VITE_API_BASE_URL=http://192.168.10.121:8000

# Cloudflare Turnstile site key (public, for CAPTCHA alternative on register and forgot-password forms)
# Get keys from https://dash.cloudflare.com/?to=/:account/turnstile
# VITE_TURNSTILE_SITE_KEY=0x4AAAAAACWncPZW1kU5S-fO
